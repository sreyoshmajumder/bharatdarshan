# BharatDarshan Backend Environment Variables
# -------------------------------------------
# DO NOT COMMIT THIS FILE — it is in .gitignore
# Copy/paste these values into your Render.com dashboard under Environment

PORT=4000

# GNews API — real-time India news
GNEWS_API_KEY=3829505661f3960e1395f0446ccd4e94

# JWT secret for auth tokens — change this in production!
JWT_SECRET=change-me-to-a-long-random-string-in-production

# Node environment
NODE_ENV=development

# Allowed frontend origin (set to your Vercel URL after deployment)
# ALLOWED_ORIGIN=https://bharatdarshan.vercel.app
